                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 0},
                        Size = {0.4, 0, 1, 0},
                        Text = dropdownConfig.Name,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    local DropdownButton = Utility:Create("TextButton", {
                        Parent = Dropdown.Frame,
                        BackgroundColor3 = self.Colors.Tertiary,
                        BorderSizePixel = 0,
                        Position = {0.4, 5, 0, 0},
                        Size = {0.6, -10, 0, 30},
                        Text = Dropdown.Value,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 13
                    })
                    
                    Utility:Create("UICorner", {
                        Parent = DropdownButton,
                        CornerRadius = UDim.new(0, 4)
                    })
                    
                    local OptionContainer = Utility:Create("ScrollingFrame", {
                        Parent = Dropdown.Frame,
                        BackgroundColor3 = self.Colors.Secondary,
                        BorderSizePixel = 0,
                        Position = {0.4, 5, 0, 35},
                        Size = {0.6, -10, 0, 0},
                        CanvasSize = {0, 0, 0, 0},
                        ScrollBarThickness = 2,
                        Visible = false,
                        ZIndex = 10
                    })
                    
                    Utility:Create("UIListLayout", {
                        Parent = OptionContainer,
                        SortOrder = Enum.SortOrder.LayoutOrder
                    })
                    
                    local function buildOptions()
                        for _, child in pairs(OptionContainer:GetChildren()) do
                            if child:IsA("TextButton") then
                                child:Destroy()
                            end
                        end
                        
                        local totalHeight = 0
                        for _, option in ipairs(Dropdown.Options) do
                            local OptionButton = Utility:Create("TextButton", {
                                Parent = OptionContainer,
                                BackgroundColor3 = self.Colors.Tertiary,
                                BorderSizePixel = 0,
                                Size = {1, 0, 0, 28},
                                Text = option,
                                TextColor3 = self.Colors.Text,
                                Font = Enum.Font.Gotham,
                                TextSize = 13,
                                ZIndex = 10
                            })
                            
                            OptionButton.MouseButton1Click:Connect(function()
                                Dropdown.Value = option
                                DropdownButton.Text = option
                                Dropdown.IsOpen = false
                                OptionContainer.Visible = false
                                
                                if dropdownConfig.Callback then
                                    dropdownConfig.Callback(option)
                                end
                            end)
                            
                            totalHeight = totalHeight + 28
                        end
                        
                        OptionContainer.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
                    end
                    
                    buildOptions()
                    
                    DropdownButton.MouseButton1Click:Connect(function()
                        Dropdown.IsOpen = not Dropdown.IsOpen
                        OptionContainer.Visible = Dropdown.IsOpen
                        if Dropdown.IsOpen then
                            OptionContainer.Size = UDim2.new(0.6, -10, 0, math.min(#Dropdown.Options * 28, 120))
                        else
                            OptionContainer.Size = UDim2.new(0.6, -10, 0, 0)
                        end
                    end)
                    
                    function Dropdown:Refresh(newOptions)
                        Dropdown.Options = newOptions
                        buildOptions()
                    end
                    
                    return Dropdown
                end,
                
                CreateLabel = function(self, labelConfig)
                    local Label = Utility:Create("Frame", {
                        Parent = Section.Container,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 0, 20}
                    })
                    
                    Utility:Create("TextLabel", {
                        Parent = Label,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 1, 0},
                        Text = labelConfig.Text,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    return Label
                end
            }
            
            return SectionAPI
        end
        
        if #Window.Tabs == 0 then
            Tab.Content.Visible = true
            Tab.Button.BackgroundColor3 = self.Colors.Accent
            Window.ActiveTab = Tab
        end
        
        table.insert(Window.Tabs, Tab)
        return Tab
    end
    
    return Window
end

function Library:Notify(config)
    local Title = config.Title or "Notification"
    local Content = config.Content or ""
    local Duration = config.Duration or 3
    
    local yOffset = 10 + (#self.Notifications * 65)
    
    local NotifFrame = Utility:Create("Frame", {
        Parent = self.ScreenGui,
        BackgroundColor3 = self.Colors.Secondary,
        BorderSizePixel = 0,
        Position = {1, -260, 0, yOffset},
        Size = {0, 250, 0, 55},
        AnchorPoint = {1, 0},
        ZIndex = 100
    })
    
    Utility:Create("UICorner", {
        Parent = NotifFrame,
        CornerRadius = UDim.new(0, 6)
    })
    
    Utility:Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = {0, 8, 0, 3},
        Size = {1, -16, 0, 18},
        Text = Title,
        TextColor3 = self.Colors.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    Utility:Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = {0, 8, 0, 24},
        Size = {1, -16, 0, 24},
        Text = Content,
        TextColor3 = self.Colors.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    })
    
    local Notification = {Frame = NotifFrame}
    table.insert(self.Notifications, Notification)
    
    task.delay(Duration, function()
        if NotifFrame then
            Utility:Tween(NotifFrame, {
                Position = UDim2.new(1, 10, 0, NotifFrame.Position.Y.Offset),
                BackgroundTransparency = 1
            }, 0.3)
            
            task.wait(0.3)
            NotifFrame:Destroy()
            
            for i, notif in ipairs(self.Notifications) do
                if notif == Notification then
                    table.remove(self.Notifications, i)
                    break
                end
            end
            
            for i, notif in ipairs(self.Notifications) do
                Utility:Tween(notif.Frame, {
                    Position = UDim2.new(1, -260, 0, 10 + ((i - 1) * 65))
                }, 0.3)
            end
        end
    end)
end

