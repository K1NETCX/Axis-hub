-- Utility Functions
local Utility = {}

function Utility:Create(className, properties)
    local instance = Instance.new(className)
    if properties then
        for prop, value in pairs(properties) do
            if prop == "Position" and type(value) == "table" then
                instance.Position = UDim2.new(value[1] or 0, value[2] or 0, value[3] or 0, value[4] or 0)
            elseif prop == "Size" and type(value) == "table" then
                instance.Size = UDim2.new(value[1] or 0, value[2] or 0, value[3] or 0, value[4] or 0)
            elseif prop == "BackgroundColor3" and type(value) == "table" then
                instance.BackgroundColor3 = Color3.fromRGB(value[1], value[2], value[3])
            elseif prop == "TextColor3" and type(value) == "table" then
                instance.TextColor3 = Color3.fromRGB(value[1], value[2], value[3])
            elseif prop == "BorderColor3" and type(value) == "table" then
                instance.BorderColor3 = Color3.fromRGB(value[1], value[2], value[3])
            else
                instance[prop] = value
            end
        end
    end
    return instance
end

function Utility:Tween(instance, properties, duration)
    local tweenInfo = TweenInfo.new(duration or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = Services.TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

function Utility:Dragify(frame, dragObject)
    local dragging, dragStart, startPos
    local dragObj = dragObject or frame
    
    dragObj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    dragObj.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                         input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- Library Definition
local Library = {}
Library.__index = Library

function Library.new(config)
    local self = setmetatable({}, Library)
    
    self.Config = config or {}
    self.Colors = {
        Background = Color3.fromRGB(25, 25, 30),
        Secondary = Color3.fromRGB(35, 35, 40),
        Tertiary = Color3.fromRGB(45, 45, 50),
        Accent = Color3.fromRGB(100, 150, 255),
        Text = Color3.fromRGB(255, 255, 255),
        SubText = Color3.fromRGB(180, 180, 185),
        Border = Color3.fromRGB(50, 50, 55)
    }
    
    self.ScreenGui = Utility:Create("ScreenGui", {
        Name = "UILibrary",
        Parent = Services.CoreGui,
        IgnoreGuiInset = true
    })
    
    if gethui then
        self.ScreenGui.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(self.ScreenGui)
    end
    
    self.Notifications = {}
    
    return self
end

