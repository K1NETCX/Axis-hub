                CreateSlider = function(self, sliderConfig)
                    local Slider = {
                        Min = sliderConfig.Range[1] or 0,
                        Max = sliderConfig.Range[2] or 100,
                        Value = sliderConfig.CurrentValue or 50
                    }
                    
                    Slider.Frame = Utility:Create("Frame", {
                        Parent = Section.Container,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 0, 50}
                    })
                    
                    local ValueLabel = Utility:Create("TextLabel", {
                        Parent = Slider.Frame,
                        BackgroundTransparency = 1,
                        Position = {0, 0, 0, 0},
                        Size = {1, 0, 0, 20},
                        Text = sliderConfig.Name .. ": " .. Slider.Value,
                        TextColor3 = self.Colors.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    local SliderFrame = Utility:Create("Frame", {
                        Parent = Slider.Frame,
                        BackgroundColor3 = self.Colors.Tertiary,
                        BorderSizePixel = 0,
                        Position = {0, 0, 0, 22},
                        Size = {1, 0, 0, 8}
                    })
                    
                    Utility:Create("UICorner", {
                        Parent = SliderFrame,
                        CornerRadius = UDim.new(0, 4)
                    })
                    
                    local Fill = Utility:Create("Frame", {
                        Parent = SliderFrame,
                        BackgroundColor3 = self.Colors.Accent,
                        BorderSizePixel = 0,
                        Size = {(Slider.Value - Slider.Min) / (Slider.Max - Slider.Min), 0, 1, 0}
                    })
                    
                    Utility:Create("UICorner", {
                        Parent = Fill,
                        CornerRadius = UDim.new(0, 4)
                    })
                    
                    local SliderButton = Utility:Create("TextButton", {
                        Parent = SliderFrame,
                        BackgroundTransparency = 1,
                        Size = {1, 0, 1, 0},
                        Text = ""
                    })
                    
                    local function updateSlider()
                        local mousePos = Services.UserInputService:GetMouseLocation()
                        local sliderPos = SliderFrame.AbsolutePosition
                        local sliderSize = SliderFrame.AbsoluteSize
                        
                        local relativeX = math.clamp((mousePos.X - sliderPos.X) / sliderSize.X, 0, 1)
                        Slider.Value = math.floor(Slider.Min + (Slider.Max - Slider.Min) * relativeX)
                        
                        Fill.Size = UDim2.new(relativeX, 0, 1, 0)
                        ValueLabel.Text = sliderConfig.Name .. ": " .. Slider.Value
                        
                        if sliderConfig.Callback then
                            sliderConfig.Callback(Slider.Value)
                        end
                    end
                    
                    SliderButton.MouseButton1Down:Connect(function()
                        updateSlider()
                        local connection
                        connection = Services.UserInputService.InputChanged:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseMovement then
                                updateSlider()
                            end
                        end)
                        
                        Services.UserInputService.InputEnded:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                connection:Disconnect()
                            end
                        end)
                    end)
                    
                    return Slider
                end,
                
                CreateDropdown = function(self, dropdownConfig)
                    local Dropdown = {
                        Options = dropdownConfig.Options or {},
                        Value = dropdownConfig.CurrentOption or dropdownConfig.Options[1],
                        IsOpen = false
                    }
                    
                    Dropdown.Frame = Utility:Create("Frame", {
