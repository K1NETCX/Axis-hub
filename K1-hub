            Tab.Content.Visible = true
            Tab.Button.BackgroundColor3 = Colors.Accent
            Window.ActiveTab = Tab
        end
        
        table.insert(Window.Tabs, Tab)
        
        -- Update canvas size
        local totalHeight = (#Window.Tabs * 40) + (#Window.Tabs - 1) * 5
        Window.TabButtons.CanvasSize = UDim2.new(0, 0, 0, totalHeight + 10)
        
        return Tab
    end
    
    table.insert(self.Windows, Window)
    return Window
end

function Library:Notify(config)
    local Title = config.Title or "Notification"
    local Content = config.Content or ""
    local Duration = config.Duration or 3
    local Type = config.Type or "Info"
    
    local yOffset = 10 + (#self.Notifications * 70)
    
    local typeColors = {
        Success = Colors.Success,
        Info = Colors.Info,
        Warning = Colors.Warning,
        Error = Colors.Error
    }
    
    local NotifFrame = Utility:Create("Frame", {
        Parent = self.ScreenGui,
        BackgroundColor3 = Colors.Secondary,
        BorderSizePixel = 0,
        Position = {1, -310, 0, yOffset},
        Size = {0, 300, 0, 60},
        AnchorPoint = {1, 0},
        ZIndex = 100
    })
    
    Utility:Create("UICorner", {
        Parent = NotifFrame,
        CornerRadius = UDim.new(0, 6)
    })
    
    Utility:Create("Frame", {
        Parent = NotifFrame,
        BackgroundColor3 = typeColors[Type] or Colors.Info,
        BorderSizePixel = 0,
        Size = {0, 4, 1, 0}
    })
    
    Utility:Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = {0, 10, 0, 5},
        Size = {1, -20, 0, 20},
        Text = Title,
        TextColor3 = Colors.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    Utility:Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = {0, 10, 0, 30},
        Size = {1, -20, 0, 20},
        Text = Content,
        TextColor3 = Colors.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    })
    
    local Notification = {Frame = NotifFrame}
    table.insert(self.Notifications, Notification)
    
    task.delay(Duration, function()
        if NotifFrame then
            Utility:Tween(NotifFrame, {
                Position = UDim2.new(1, 10, 0, NotifFrame.Position.Y.Offset),
                BackgroundTransparency = 1
            }, 0.3)
            
            task.wait(0.3)
            NotifFrame:Destroy()
            
            for i, notif in ipairs(self.Notifications) do
                if notif == Notification then
                    table.remove(self.Notifications, i)
                    break
                end
            end
            
            for i, notif in ipairs(self.Notifications) do
                Utility:Tween(notif.Frame, {
                    Position = UDim2.new(1, -310, 0, 10 + ((i - 1) * 70))
                }, 0.3)
            end
        end
    end)
end

function Library:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

