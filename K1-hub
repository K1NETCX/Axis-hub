local RayfieldAPI = {
    CreateWindow = function(config)
        local Lib = Library.new(config)
        
        return {
            CreateWindow = function(windowConfig)
                return Lib:CreateWindow(windowConfig)
            end,
            
            Notify = function(notifyConfig)
                Lib:Notify(notifyConfig)
            end,
            
            Destroy = function()
                Lib:Destroy()
            end
        }
    end
}

